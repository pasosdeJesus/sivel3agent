# ====================================================================
#      UNIFIED ENVIRONMENT CONFIGURATION FOR SIVEL3AGENT
# ====================================================================
# Copy this file to apps/.env and fill in your values.
# ====================================================================

# --------------------------------------------------------------------
# BLOCKCHAIN & DEPLOYMENT CONFIGURATION (Used by Hardhat)
# --------------------------------------------------------------------

# IMPORTANT: Use a dedicated development wallet, not one with real funds.
PRIVATE_KEY="0x..."

# API key for verifying contracts on Celo's Blockscout explorer.
BLOCKSCOUT_API_KEY=""

# API key for verifying contracts on Base's explorer.
BASESCAN_API_KEY=""

# --------------------------------------------------------------------
# NEXT.JS & FRONTEND CONFIGURATION
# --------------------------------------------------------------------

NEXT_PUBLIC_APPNAME='SIVEL 3 AGENT'
NEXT_PUBLIC_WC_PROJECT_ID=''

# Generate with `openssl rand -hex 32`
NEXTAUTH_SECRET=

# --------------------------------------------------------------------
#      SHARED CONFIGURATION
# --------------------------------------------------------------------

# Network: celo (mainnet) or celoSepolia (testnet)
NEXT_PUBLIC_NETWORK=celoSepolia
NEXT_PUBLIC_RPC_URL="https://forno.celo-sepolia.celo-testnet.org/"

NEXT_PUBLIC_USDT_DECIMALS=6
NEXT_PUBLIC_SLEARN_ADDRESS=
NEXT_PUBLIC_EXPLORER_TX=https://celo-sepolia.blockscout.com/tx/

# --------------------------------------------------------------------
#      DATABASE CONFIGURATION
# --------------------------------------------------------------------
PGHOST=localhost
PGDATABASE=sivel3agent_dev
PGUSER=sivel3agent
PGPASSWORD=changeme
PG_SUPERUSER=postgres

# --------------------------------------------------------------------
#      AGENT CONFIGURATION
# --------------------------------------------------------------------
AGENT_WALLET_NAME=sivel3agent
AGENT_WALLET_ADDRESS=0x8C88169977c180f6380C01daAA9c7F31894c20dc
