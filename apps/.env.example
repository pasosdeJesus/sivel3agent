# ====================================================================
#      UNIFIED ENVIRONMENT CONFIGURATION FOR SIVEL3AGENT
# ====================================================================
# This file serves as the single source of truth for both the
# Hardhat (backend) and Next.js (frontend) applications.
#
# Standard: .env.example
# ====================================================================

# --------------------------------------------------------------------
# BLOCKCHAIN & DEPLOYMENT CONFIGURATION (Used by Hardhat)
# --------------------------------------------------------------------

# sivel.xyz backend wallet (MINTER_ROLE on PasosDeJesusCredentials, deployer of other contracts).
# IMPORTANT: Use a dedicated development wallet, not one with real funds.
PRIVATE_KEY="0xa...80"

# PasosDeJesusCredentials admin wallet (DEFAULT_ADMIN_ROLE). Generated via:
#   cd apps/hardhat && node scripts/generate-wallet.mjs
CREDENTIALS_PRIVATE_KEY=""

# API key for verifying contracts on Celo's Blockscout explorer.
BLOCKSCOUT_API_KEY=""

# API key for verifying contracts on Base's explorer.
BASESCAN_API_KEY=""


# --------------------------------------------------------------------
# NEXT.JS & FRONTEND CONFIGURATION
# --------------------------------------------------------------------

# -- General App Info --
NEXT_PUBLIC_APPNAME='SIVEL 3 AGENT'
NEXT_PUBLIC_WC_PROJECT_ID='9...2'

# Generate with `openssl rand -hex 32`
NEXTAUTH_SECRET=22316ee69acdbbe46c46661ce250a525e7e794a03f065fd39bff983b2f559780

# --------------------------------------------------------------------
#      SHARED CONFIGURATION (Used by BOTH Hardhat & Next.js)
# --------------------------------------------------------------------

# -- Network Configuration --
# Celo: celo (mainnet), celoSepolia (testnet)
NEXT_PUBLIC_NETWORK=celoSepolia
NEXT_PUBLIC_RPC_URL="https://lb.drpc.org/celo-sepolia/x"

# -- Contract Addresses & Details --
NEXT_PUBLIC_USDT_DECIMALS=6

# SLEARN token (cashback rewards for verified donors)
NEXT_PUBLIC_SLEARN_ADDRESS=

# -- Explorer URL --
NEXT_PUBLIC_EXPLORER_TX=https://celo-sepolia.blockscout.com/tx/


# --------------------------------------------------------------------
#      DATABASE CONFIGURATION (Used by Next.js)
# --------------------------------------------------------------------
PGHOST=/var/run/postgresql/
PGDATABASE=sivel3agent_dev
PGUSER=sivel3agent
PGPASSWORD=clave
PG_SUPERUSER=postgres

