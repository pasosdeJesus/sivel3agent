        "PROCESOS ELECTORALES",
        "PROTESTA",
        "RESTITUCIÓN DE TIERRAS",
        "SEGURIDAD INFORMÁTICA",
        "TOMA DE TIERRAS",
        "ZONAS DE REHAB. Y CONSOL"
      ]
    },
    "fuente": {
      "type": "object",
      "properties": {
        "nombre_fuente": { "type": "string" },
        "fecha_fuente": { 
          "type": ["string", "null"],
          "format": "date"
        },
        "ubicacion_fuente": { "type": ["string", "null"] },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      },
      "required": ["nombre_fuente"]
    },
    "combatiente": {
      "type": "object",
      "properties": {
        "nombre": { "$ref": "#/$defs/mayusculas" },
        "alias": { "type": ["string", "null"] },
        "edad": { "type": ["string", "null"] },
        "sexo": { 
          "type": ["string", "null"],
          "enum": ["M", "F", null]
        },
        "ocupacion": { 
          "type": ["string", "null"],
          "enum": [
            "DEFENSOR/A DE DDHH",
            "LIDER(ESA) SOCIAL",
            "CAMPESINO",
            "INDIGENA",
            "COMERCIANTE",
            "OBRERO",
            "PROFESIONAL",
            "DESEMPLEADO (A)",
            "SIN INFORMACIÓN",
            null
          ]
        },
        "filiacion": { "type": ["string", "null"] },
        "sector_condicion": { 
          "type": ["string", "null"],
          "enum": [
            "AMBIENTALISTA",
            "CAMPESINO",
            "LIDER(ESA) SOCIAL",
            "SIN INFORMACIÓN",
            null
          ]
        },
        "organizacion": { 
          "type": ["string", "null"],
          "enum": [
            "COMUNAL",
            "DERECHOS HUMANOS",
            "SINDICAL",
            "SIN INFORMACIÓN",
            null
          ]
        },
        "organizacion_armada": { 
          "type": ["string", "null"],
          "enum": [
            "EJÉRCITO",
            "GUERRILLA",
            "PARAMILITARES",
            "SIN INFORMACIÓN",
            null
          ]
        },
        "resultado_agresion": { "type": ["string", "null"] },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      }
    },
    "ubicacion_secundaria": {
      "type": "object",
      "properties": {
        "departamento": { 
          "type": ["string", "null"],
          "enum": [
            "Amazonas", "Antioquia", "Arauca", "Atlántico", "Bogotá D.C.",
            "Bolívar", "Boyacá", "Caldas", "Caquetá", "Casanare", "Cauca",
            "Cesar", "Chocó", "Córdoba", "Cundinamarca", "Guainía", "Guaviare",
            "Huila", "La Guajira", "Magdalena", "Meta", "Nariño", "Norte de Santander",
            "Putumayo", "Quindío", "Risaralda", "San Andrés y Providencia",
            "Santander", "Sucre", "Tolima", "Valle del Cauca", "Vaupés", "Vichada",
            null
          ]
        },
        "municipio": { "type": ["string", "null"] },
        "centro_poblado": { "type": ["string", "null"] },
        "longitud": { "type": ["string", "null"] },
        "latitud": { "type": ["string", "null"] },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      }
    },
    "observacion": {
      "type": "object",
      "properties": {
        "tipo": { 
          "type": "string",
          "enum": [
            "intervalo",
            "region",
            "sitio",
            "lugar",
            "tsitio",
            "contexto",
            "etnia",
            "subdivision",
            "bloque",
            "frente",
            "otro",
            "filiacion",
            "orientacionsexual",
            "vinculoestado",
            "anotaciones",
            "grinformacion",
            "grconfiabilidad",
            "gresclarecimiento",
            "grimpunidad",
            "bienes",
            "frontera",
            "organizacion_armada",
            "rangoedad",
            "hijos"
          ]
        },
        "texto": { "type": "string" }
      },
      "required": ["tipo", "texto"],
      "allOf": [
        {
          "if": {
            "properties": { "tipo": { "const": "intervalo" } }
          },
          "then": {
            "properties": {
              "texto": { 
                "enum": ["MADRUGADA", "MAÑANA", "TARDE", "NOCHE", "SIN INFORMACIÓN"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "tipo": { "const": "tsitio" } }
          },
          "then": {
            "properties": {
              "texto": { "enum": ["RURAL", "URBANO"] }
            }
          }
        },
        {
          "if": {
            "properties": { "tipo": { "const": "orientacionsexual" } }
          },
          "then": {
            "properties": {
              "texto": { 
                "enum": [
                  "S",
                  "LGBTI",
                  "HOMOSEXUAL",
                  "BISEXUAL",
                  "TRANSGENERO",
                  "LESBIANA",
                  "GAY",
                  "SIN INFORMACIÓN"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "tipo": { "const": "region" } }
          },
          "then": {
            "properties": {
              "texto": { 
                "enum": [
                  "AMAZONÍA",
                  "ANTIOQUIA CHOCO SANT",
                  "CENTRO",
                  "COSTA ATLANTICA",
                  "COSTA PACIFICA",
                  "EJE CAFETERO Y TOLIMA GRANDE",
                  "EXTERIOR",
                  "LLANOS",
                  "MAGDALENAMEDIOSURDECESARYSURDEBOLIVAR",
                  "SUR OCCIDENTE",
                  "SIN INFORMACIÓN"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "tipo": { "const": "etnia" } }
          },
          "then": {
            "properties": {
              "texto": { 
                "enum": [
                  "INDÍGENA",
                  "AFROCOLOMBIANO",
                  "ROM",
                  "RAIZAL",
                  "PALENQUERO",
                  "SIN INFORMACIÓN"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
