{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sivel.xyz/schemas/relato.schema.json",
  "title": "Relato de Violencia Política",
  "description": "Esquema JSON equivalente al DTD relatos-099.dtd del Banco de Datos del CINEP. Incluye tesauros completos del marco conceptual y reglas de formato del SKILL.",
  "type": "object",
  "properties": {
    "relatos": {
      "type": "array",
      "items": { "$ref": "#/$defs/relato" },
      "minItems": 1
    }
  },
  "required": ["relatos"],
  "$defs": {
    "mayusculas": {
      "type": "string",
      "pattern": "^[A-ZÁÉÍÓÚÑ][A-ZÁÉÍÓÚÑ ]*$"
    },
    "fecha_valida": {
      "type": "string",
      "pattern": "^\\d{4}-(\\d{2}|00)-(\\d{2}|00)$"
    },
    "relato": {
      "type": "object",
      "properties": {
        "organizacion_responsable": { 
          "type": "string",
          "const": "Banco de Datos del CINEP"
        },
        "derechos": { 
          "type": "string",
          "const": "Creative Commons Atribución 2.5 Colombia"
        },
        "id_relato": { 
          "type": "string",
          "readOnly": true
        },
        "forma_compartir": { 
          "type": "string",
          "enum": ["publico", "privado", "restringido"]
        },
        "titulo": { 
          "type": ["string", "null"],
          "maxLength": 50
        },
        "hechos": { 
          "type": "string"
        },
        "personas": {
          "type": "array",
          "items": { "$ref": "#/$defs/persona" }
        },
        "grupos": {
          "type": "array",
          "items": { "$ref": "#/$defs/grupo" }
        },
        "victimas": {
          "type": "array",
          "items": { "$ref": "#/$defs/victima" }
        },
        "presuntos_responsables_individuales": {
          "type": "array",
          "items": { "$ref": "#/$defs/presunto_responsable_individual" }
        },
        "fecha": { 
          "type": ["string", "null"],
          "$ref": "#/$defs/fecha_valida"
        },
        "hora": { 
          "type": ["string", "null"],
          "pattern": "^(0[0-9]|1[0-2]):[0-5][0-9] (AM|PM)$"
        },
        "duracion": { "type": ["string", "null"] },
        "ubicaciones_secundarias": {
          "type": "array",
          "items": { "$ref": "#/$defs/ubicacion_secundaria" }
        },
        "departamento": { 
          "type": ["string", "null"],
          "enum": [
            "Amazonas", "Antioquia", "Arauca", "Atlántico", "Bogotá D.C.",
            "Bolívar", "Boyacá", "Caldas", "Caquetá", "Casanare", "Cauca",
            "Cesar", "Chocó", "Córdoba", "Cundinamarca", "Guainía", "Guaviare",
            "Huila", "La Guajira", "Magdalena", "Meta", "Nariño", "Norte de Santander",
            "Putumayo", "Quindío", "Risaralda", "San Andrés y Providencia",
            "Santander", "Sucre", "Tolima", "Valle del Cauca", "Vaupés", "Vichada",
            null
          ]
        },
        "municipio": { "type": ["string", "null"] },
        "centro_poblado": { "type": ["string", "null"] },
        "longitud": { "type": ["string", "null"] },
        "latitud": { "type": ["string", "null"] },
        "actos": {
          "type": "array",
          "items": { "$ref": "#/$defs/acto" }
        },
        "contextos": {
          "type": "array",
          "items": { "$ref": "#/$defs/contexto_valor" }
        },
        "fuentes": {
          "type": "array",
          "items": { "$ref": "#/$defs/fuente" }
        },
        "acciones_juridicas": {
          "type": ["object", "null"],
          "properties": {
            "observaciones": {
              "type": "array",
              "items": { "$ref": "#/$defs/observacion" }
            }
          }
        },
        "otras_acciones": { "type": ["string", "null"] },
        "fecha_publicacion": { 
          "type": ["string", "null"],
          "readOnly": true,
          "format": "date-time"
        },
        "anexo": {
          "type": ["object", "null"],
          "properties": {
            "observaciones": {
              "type": "array",
              "items": { "$ref": "#/$defs/observacion" }
            }
          }
        },
        "combatientes": {
          "type": "array",
          "items": { "$ref": "#/$defs/combatiente" }
        },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      },
      "required": ["organizacion_responsable", "derechos", "id_relato", "forma_compartir", "hechos"]
    },
    "persona": {
      "type": "object",
      "properties": {
        "id_persona": { "type": "string" },
        "nombre": { "$ref": "#/$defs/mayusculas" },
        "nombre2": { "$ref": "#/$defs/mayusculas" },
        "apellido": { "$ref": "#/$defs/mayusculas" },
        "apellido2": { "$ref": "#/$defs/mayusculas" },
        "docid": { "type": ["string", "null"] },
        "fecha_nacimiento": { 
          "type": ["string", "null"],
          "$ref": "#/$defs/fecha_valida"
        },
        "sexo": { 
          "type": ["string", "null"],
          "enum": ["M", "F", null]
        },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      },
      "required": ["id_persona"]
    },
    "grupo": {
      "type": "object",
      "properties": {
        "id_grupo": { 
          "type": ["string", "null"],
          "enum": ["4", "5", "6", "7", "14", "25", "35", "38", "51", null]
        },
        "nombre_grupo": { "$ref": "#/$defs/mayusculas" },
        "sigla": { "type": ["string", "null"] },
        "subgrupo_de": { "type": ["string", "null"] },
        "agresion_sin_vicd": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      }
    },
    "victima": {
      "type": "object",
      "properties": {
        "id_persona": { "type": "string" },
        "ocupacion": { 
          "type": ["string", "null"],
          "enum": [
            "DEFENSOR/A DE DDHH",
            "LIDER(ESA) SOCIAL",
            "CAMPESINO",
            "INDIGENA",
            "COMERCIANTE",
            "OBRERO",
            "PROFESIONAL",
            "DESEMPLEADO (A)",
            "SIN INFORMACIÓN",
            null
          ]
        },
        "sector_condicion": { 
          "type": ["string", "null"],
          "enum": [
            "AMBIENTALISTA",
            "CAMPESINO",
            "COLONOS",
            "COMERCIANTE",
            "DESEMPLEADO (A)",
            "DESMOVILIZADO(A)",
            "EMPLEADO",
            "EMPRESARIO",
            "ESTILISTA",
            "ETNIAS - NEGRITUDES",
            "EXCOMBATIENTES",
            "GANADERO",
            "HACENDADO",
            "IGLESIAS",
            "INDIGENA",
            "INDUSTRIAL",
            "LGBT",
            "LIDER(ESA) SOCIAL",
            "MARGINADO",
            "MINERO",
            "OBRERO",
            "PROFESIONAL",
            "SIN INFORMACIÓN",
            "TRABAJADOR (A) SEXUAL",
            "TRABAJADOR INDEPENDIENTE",
            "TRANSPORTADOR",
            "VENDEDOR AMBULANTE",
            "VÍCTIMA",
            null
          ]
        },
        "iglesia": { "type": ["string", "null"] },
        "organizacion": { 
          "type": ["string", "null"],
          "enum": [
            "AMBIENTALISTA",
            "CAMPESINA",
            "CIVICA",
            "COMUNAL",
            "DERECHOS HUMANOS",
            "DESPLAZADOS",
            "ESTUDIANTIL",
            "FEMENINA",
            "GREMIAL",
            "HUMANITARIA",
            "INDIGENA",
            "JUVENIL",
            "LGTB",
            "NEGRITUDES",
            "PAZ",
            "PROFESIONAL",
            "RELIGIOSA",
            "SIN INFORMACIÓN",
            "SINDICAL",
            "VÍCTIMAS",
            null
          ]
        },
        "id_grupo": { 
          "type": ["string", "null"],
          "enum": ["4", "5", "6", "7", "14", "25", "35", null]
        },
        "estado_tras_hecho": { "type": ["string", "null"] },
        "danio_directo": { "type": ["string", "null"] },
        "danio_indirecto": { "type": ["string", "null"] },
        "personas_dependientes": { "type": ["string", "null"] },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      },
      "required": ["id_persona"]
    },
    "presunto_responsable_individual": {
      "type": "object",
      "properties": {
        "id_persona": { "type": "string" },
        "id_grupo": { 
          "type": ["string", "null"],
          "enum": ["4", "5", "6", "7", "14", "25", "35", null]
        },
        "alias": { "type": ["string", "null"] },
        "agresion_sin_vicd": {
          "type": "array",
          "items": { "type": "string" }
        },
        "observaciones": {
          "type": "array",
          "items": { "$ref": "#/$defs/observacion" }
        }
      },
      "required": ["id_persona"]
    },
